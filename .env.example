# Ambiente
NODE_ENV=production
PORT=3000

# Domínio público principal do TrackServer
# Clientes podem apontar CNAMEs para este host.
TRACK_SERVER_PUBLIC_HOST=track.seudominio.com
TRACK_SERVER_ADMIN_SECRET=<TRACK_SERVER_ADMIN_SECRET>

# Meta
META_API_VERSION=v22.0

# Banco de Dados
POSTGRES_USER=<POSTGRES_USER>
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>
POSTGRES_DB=trackserver
DATABASE_URL=postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@postgres:5432/trackserver?schema=public

# Cache & Fila
REDIS_PASSWORD=<REDIS_PASSWORD>
REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379/0

# Segurança e Criptografia
# ENCRYPTION_KEY deve ter exatamente 32 bytes, ou seja, 64 caracteres hexadecimais.
ENCRYPTION_KEY=<64_HEX_CHAR_ENCRYPTION_KEY>
JWT_SECRET=<JWT_SECRET>

# Painel Administrativo do TrackServer
ADMIN_USER=admin
ADMIN_PASSWORD=<ADMIN_PASSWORD>

# Grafana
GF_SECURITY_ADMIN_PASSWORD=<GRAFANA_ADMIN_PASSWORD>
