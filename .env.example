# Ambiente
NODE_ENV=production
PORT=3000

# Banco de Dados
DATABASE_URL=postgresql://postgres:postgres_secure_pass@postgres:5432/trackserver?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_DB=trackserver

# Cache & Fila
REDIS_URL=redis://:redis_secure_pass@redis:6379/0
REDIS_PASSWORD=redis_secure_pass

# Segurança e Criptografia
# ENCRYPTION_KEY deve ter exatamente 32 bytes (64 caracteres hexadecimais)
ENCRYPTION_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
JWT_SECRET=super_secret_jwt_key_change_me

# Painel Administrativo do TrackServer
ADMIN_USER=admin
ADMIN_PASSWORD=admin_secure_pass

# Grafana
GF_SECURITY_ADMIN_PASSWORD=admin_secure_pass
